class SIEMPipeline {
private:
    std::vector<std::string> eventBuffer; const size_t BATCH_SIZE = 5;
    void Transmit(const std::string& payload) {
        WSADATA wsaData;
        if (WSAStartup(MAKEWORD(2, 2), &wsaData) == 0) {
            SOCKET s = socket(AF_INET, SOCK_DGRAM, IPPROTO_UDP);
            if (s != INVALID_SOCKET) {
                sockaddr_in server; server.sin_family = AF_INET; server.sin_port = htons(514); server.sin_addr.s_addr = inet_addr("127.0.0.1");
                sendto(s, payload.c_str(), payload.length(), 0, (sockaddr*)&server, sizeof(server)); closesocket(s);
            }
            WSACleanup();
        }
    }
    void SendBatch() {
        if (eventBuffer.empty()) return;
        std::stringstream batchPayload; batchPayload << "[";
        for (size_t i = 0; i < eventBuffer.size(); ++i) batchPayload << eventBuffer[i] << (i < eventBuffer.size() - 1 ? "," : "");
        batchPayload << "]"; Transmit(batchPayload.str()); eventBuffer.clear();
    }
public:
    void QueueEvent(const std::string& json, const std::string& riskLevel) {
        if (riskLevel == "LOW") return; 
        if (riskLevel == "CRITICAL") { Transmit("[" + json + "]"); return; }
        eventBuffer.push_back(json); if (eventBuffer.size() >= BATCH_SIZE) SendBatch();
    }
    void Flush() { SendBatch(); }
};
